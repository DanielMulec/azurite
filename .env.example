# Copy this file to the untracked repository-root `.env.local` for an explicit
# local Sentry debug session. Keep real DSNs and credentials out of Git.

# React browser runtime (`azurite-web`)
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local-debug
VITE_SENTRY_RELEASE=azurite-local
VITE_SENTRY_TRACE_SAMPLE_RATE=1.0
VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=1.0
VITE_SENTRY_REPLAY_ERROR_SAMPLE_RATE=1.0
VITE_SENTRY_TEST_EVENTS_ENABLED=false

# Fastify backend runtime (`azurite-server`)
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=local-debug
SENTRY_RELEASE=azurite-local
SENTRY_TRACE_SAMPLE_RATE=1.0
SENTRY_TEST_EVENTS_ENABLED=false
